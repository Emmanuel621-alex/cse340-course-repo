<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <p><a href="/new-project">Add a New Service Project</a></p>

    <h2>Upcoming Service Projects</h2>

    <ul>
        <% projects.forEach(project => { %>
            <li>
                <!-- Project link -->
                <a href="/project/<%= project.project_id %>">
                    <strong><%= project.title %></strong>
                </a>
                <br>

                <%= project.description %><br>

                <!-- Organization link -->
                <strong>Organization:</strong>
                <a href="/organization/<%= project.organization_id %>">
                    <%= project.organization_name %>
                </a>
                <br>

                <strong>Location:</strong> <%= project.location %><br>

                <strong>Date:</strong> <%= project.project_date %>
            </li>
            <br>
        <% }); %>
    </ul>
</main>

<%- include('partials/footer') %>