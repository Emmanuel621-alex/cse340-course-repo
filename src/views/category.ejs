<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2><%= category.name %></h2>

    <!-- Category action (ONLY ONCE) -->
    <a href="/edit-category/<%= category.category_id %>">Edit Category</a>

    <h3>Service Projects</h3>

    <ul>
        <% projects.forEach(project => { %>
            <li>
                <a href="/project/<%= project.project_id %>">
                    <%= project.title %>
                </a>
            </li>
        <% }); %>
    </ul>
</main>

<%- include('partials/footer') %>