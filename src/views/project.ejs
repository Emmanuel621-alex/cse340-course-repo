<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <% if (user && user.role_name === 'admin') { %>
        <a href="/new-project">Add New Project</a>
    <% } %>

    <h2><%= project.title %></h2>

    <p><%= project.description %></p>

    <p>
        <strong>Date:</strong> <%= project.project_date %>
    </p>

    <p>
        <strong>Location:</strong> <%= project.location %>
    </p>

    <p>
        <strong>Organization:</strong>
        <a href="/organization/<%= project.organization_id %>">
            <%= project.organization_name %>
        </a>
    </p>

    <!-- Volunteer Section -->
    <% if (user) { %>

        <% if (!volunteerStatus) { %>

            <form action="/project/<%= project.project_id %>/volunteer" method="POST">
                <button type="submit">
                    Volunteer For This Project
                </button>
            </form>

        <% } else { %>

            <p>
                <strong>You are volunteering for this project.</strong>
            </p>

            <form action="/project/<%= project.project_id %>/remove-volunteer" method="POST">
                <button type="submit">
                    Remove Volunteer Signup
                </button>
            </form>

        <% } %>

    <% } %>

    <p>
        <a href="/edit-project/<%= project.project_id %>">
            Edit Project
        </a>
    </p>

</main>

<%- include('partials/footer') %>