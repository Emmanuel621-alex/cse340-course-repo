<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Dashboard</h2>
    <p>Name: <%= name %></p>
    <p>Username: <%= email %></p>

    <h2>Your Volunteer Projects</h2>

    <% if (volunteerProjects && volunteerProjects.length > 0) { %>
        <ul>
            <% volunteerProjects.forEach(project => { %>
                <li>
                    <strong>
                        <a href="/project/<%= project.project_id %>">
                            <%= project.title %>
                        </a>
                    </strong>

                    (<%= project.location %>)

                    <form
                        action="/project/<%= project.project_id %>/remove-volunteer"
                        method="POST"
                        style="display:inline;"
                    >
                        <button type="submit">
                            Remove
                        </button>
                    </form>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>You have not volunteered for any projects yet.</p>
    <% } %>

    <% if (user && user.role_name === 'admin') { %>
        <p>
            <a href="/users">View All Users</a>
        </p>
    <% } %>
</main>

<%- include('partials/footer') %>